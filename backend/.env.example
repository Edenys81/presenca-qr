# ============================================
# CONFIGURAÇÃO PARA RAILWAY - PRODUÇÃO
# ============================================

# AMBIENTE
NODE_ENV=production
PORT=3000

# FRONTEND URL (CRÍTICO PARA RAILWAY)
FRONTEND_URL=https://seu-app-nome.railway.app

# GOOGLE OAUTH (https://console.cloud.google.com )
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_CALLBACK_URL=https://seu-app-nome.railway.app/auth/google/callback

# BANCO DE DADOS (Railway fornece automaticamente )
DATABASE_URL=mysql://user:password@host:port/dbname
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=presenca_qr

# SESSÃO (GERAR COM: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=sua-chave-aleatoria-segura-aqui

# ADMIN EMAILS (Emails que terão acesso ao painel admin)
ADMIN_EMAILS=seu-email@example.com

# EMAIL (Para envio de certificados e notificações)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_gmail
EMAIL_FROM=Sistema de Presença <seu_email@gmail.com>

# LLM / IA (Para análises automáticas)
OPENAI_API_KEY=sua_openai_api_key_aqui
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua_chave_llm_aqui

